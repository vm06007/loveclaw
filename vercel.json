{
    "rewrites": [
        {
            "source": "/uniswap/:path*",
            "destination": "https://trade-api.gateway.uniswap.org/:path*"
        },
        {
            "source": "/relay/:path*",
            "destination": "https://loveclaw-relay.ngrok.app/:path*"
        },
        {
            "source": "/",
            "has": [{ "type": "host", "value": "web.loveclaw.app" }],
            "destination": "/web/index.html"
        },
        {
            "source": "/((?!api/|assets/|welcome/|web/|prototype/|uniswap/|relay/|favicon\\.ico|robots\\.txt).*)",
            "destination": "/index.html"
        }
    ]
}
