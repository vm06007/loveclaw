# Copy to .env.local (gitignored) and fill in secrets:
#   cp .env.local.example .env.local
#
# Optional: also use .env for non-secret defaults; .env.local overrides .env.

# testnet | galileo  (default)  /  mainnet | aristotle
OG_NETWORK=testnet

# Wallet used to sign storage txs (gas on the selected network).
PRIVATE_KEY=

# Optional: same wallet’s public address (0x…) for ChainScan “this wallet” links.
# If omitted, the address is derived from PRIVATE_KEY.
# WALLET_ADDRESS=0x...

# Optional: open the web UI at 2x zoom on first load (also: bun run ui -- --scale=2)
# UI_START_SCALE=2

# Optional: full URL overrides (otherwise chosen from OG_NETWORK)
# RPC_URL=https://evmrpc-testnet.0g.ai
# INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Mainnet (prefer OG_NETWORK=mainnet; only uncomment if you need custom hosts)
# RPC_URL=https://evmrpc.0g.ai
# INDEXER_RPC=https://indexer-storage-turbo.0g.ai
