{
  "name": "loveclaw",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "bash run.sh",
    "dev": "vite",
    "phone-demo": "bash scripts/phone-demo-ngrok.sh",
    "dev:https": "LOVECLAW_DEV_HTTPS=1 vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "bash scripts/tauri-dev.sh",
    "dev:tauri:relay": "LOVECLAW_RELAY=1 bash scripts/tauri-dev.sh",
    "dev:alice": "bash scripts/tauri-dev.sh alice",
    "dev:alice:relay": "LOVECLAW_RELAY=1 bash scripts/tauri-dev.sh alice",
    "dev:boris": "bash scripts/tauri-dev.sh boris",
    "dev:boris:relay": "LOVECLAW_RELAY=1 bash scripts/tauri-dev.sh boris",
    "dev:yiying": "bash scripts/tauri-dev.sh yiying",
    "dev:vitally": "bash scripts/tauri-dev.sh vitally",
    "dev:prebuilt:boris": "LOVECLAW_ROLE=boris ./src-tauri/target/debug/loveclaw",
    "dev:prebuilt:boris:relay": "LOVECLAW_RELAY=1 LOVECLAW_ROLE=boris ./src-tauri/target/debug/loveclaw"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "vite": "^6"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@vercel/functions": "^3.5.0",
    "jsqr": "^1.4.0",
    "leaflet": "^1.9.4",
    "qrcode": "^1.5.4"
  }
}
