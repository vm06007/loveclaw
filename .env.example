# Copy to `.env` and fill in your values. `.env` is git-ignored.

# --- AXL (live pairing / mesh control API) ---------------------------------
# Local: Vite proxies `/axl9002` → :9002 and `/axl9012` → :9012 (examples/axl-demo).
#
# Vercel + demo laptop (judge / two phones on loveclaw.app):
#   1) On your machine run two AXL nodes + two ngrok HTTP tunnels (see scripts/ngrok-two-axl.example.yml).
#   2) Open https://loveclaw.app/alice and https://loveclaw.app/boris (paths in repo `vercel.json`).
#   3) In Vercel → Project → Settings → Environment Variables (Production), set **server-side only**:
#        DEMO_AX_9002_URL=https://YOUR-ALICE-TUNNEL.ngrok-free.app
#        DEMO_AX_9012_URL=https://YOUR-BORIS-TUNNEL.ngrok-free.app
#   4) Redeploy after changing env. The SPA calls `/api/demo-axl` then `/api/demo-axl-proxy` — Vercel
#      forwards to your tunnels (no CORS). Ngrok URLs are not committed; update env when tunnels change.
#   5) After the demo, clear those env vars and redeploy so the public site is not tied to your laptop.
#
# Optional build-time bases (browser calls ngrok/origin directly — needs CORS on the node):
# VITE_AXL_NODE_9002_BASE=https://axl-alice.example.com
# VITE_AXL_NODE_9012_BASE=https://axl-boris.example.com
#
# Same-origin rewrites only (no DEMO_AX_*): vercel.axl-rewrite.example.json + VITE_AXL_VERCEL_REWRITE=1

# MapTiler raster basemap for the heartbeat map.
# Get a free key: https://cloud.maptiler.com/account/keys/
VITE_MAPTILER_KEY=

# Optional: override default style. Examples (see MapTiler docs for full list):
#   streets-v2        — colorful, all POI icons (default)
#   streets-v2-dark   — dark mode, all POI icons
#   bright-v2         — clean, modern, full detail
#   pastel            — soft pastel palette
#   voyager           — vintage colorful (CARTO-like)
#   outdoor-v2        — hiking / topo
#   topo-v2           — topographic
#   basic-v2          — minimal
#   winter-v2         — snow theme
#   streets-v2-light  — light minimal
# https://docs.maptiler.com/leaflet/examples/map-style/
VITE_MAPTILER_STYLE=streets-v2

# OpenRouter (recommended quickest way for @loveclaw chat)
# Get key: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=
# Example: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, etc.
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional ranking/debug metadata headers sent to OpenRouter
VITE_OPENROUTER_APP_URL=http://localhost:1420
VITE_OPENROUTER_APP_TITLE=LoveClaw

# Optional default provider values (users can override in-app AI settings modal)
VITE_HUGGINGFACE_API_KEY=
VITE_HUGGINGFACE_MODEL=google/gemma-2-9b-it
VITE_LOCAL_OLLAMA_URL=http://127.0.0.1:11434
VITE_LOCAL_OLLAMA_MODEL=gemma3:4b

# Optional LoveClaw LLM endpoint for @loveclaw chat replies.
# Expected response JSON shape: { "reply": "..." }
# Example (local): http://127.0.0.1:8787/loveclaw-chat
VITE_LOVECLAW_LLM_URL=

# Uniswap Trading API key — required for @loveclaw swap commands.
# Get a key at https://hub.uniswap.org/
VITE_UNISWAP_API_KEY=

# Mutual vault (couple shared wallet) — generate a fresh keypair per deployment.
# python3 -c "from eth_account import Account; a=Account.create(); print(a.address, a.key.hex())"
VITE_VAULT_ADDRESS=
VITE_VAULT_PRIVATE_KEY=
VITE_VAULT_PIN=0000

# Optional bearer token for that endpoint.
# Note: VITE_ vars are exposed to the frontend bundle. For production,
# prefer proxying via a backend/Tauri command instead of shipping secrets.
VITE_LOVECLAW_LLM_TOKEN=
